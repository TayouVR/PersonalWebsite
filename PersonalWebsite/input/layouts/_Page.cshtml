@{
    Layout = "/layouts/_Layout.cshtml";
}

<div class="container mx-auto px-4 py-12">
    <div class="prose lg:prose-xl mx-auto">
        @if (Document.ContainsKey("Title"))
        {
            <h1 class="text-center">@Document.GetString("Title")</h1>
        }
        @RenderBody()
    </div>
</div>
