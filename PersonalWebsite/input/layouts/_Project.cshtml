@{
    Layout = "/layouts/_Layout.cshtml";
    var tags = Document.GetList<string>("tags") ?? new List<string>();
}

<div class="container mx-auto px-4 py-12">
    <div class="max-w-4xl mx-auto">
        <div class="mb-8">
            <a href="/projects" class="btn btn-ghost btn-sm mb-4">← Back to Projects</a>
            <h1 class="text-4xl font-bold mb-4">@Document.GetString("Title")</h1>
            
            @if (Document.ContainsKey("image"))
            {
                <img src="@Document.GetString("image")" alt="@Document.GetString("Title")" class="w-full h-64 object-cover rounded-xl mb-6 shadow-lg" />
            }

            <div class="flex flex-wrap gap-2 mb-8">
                @foreach (var tag in tags)
                {
                    <span class="badge badge-outline">@tag</span>
                }
            </div>
        </div>

        <div class="prose lg:prose-xl max-w-none">
            @RenderBody()
        </div>
    </div>
</div>
